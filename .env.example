# Core application
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/property_pros"
AUTH_SECRET="replace-with-a-long-random-secret"
NEXTAUTH_URL="http://localhost:5000"

# Optional OAuth providers. Set both values for a provider or leave both blank.
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
APPLE_CLIENT_ID=""
APPLE_CLIENT_SECRET=""

# SMTP mail delivery. Required outside local development for verification and reset emails.
SMTP_HOST=""
SMTP_PORT=""
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM=""
SMTP_SECURE=""

# Stripe billing. Required to enable paid Pro and Realtor subscriptions.
STRIPE_SECRET_KEY=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_PRO_PRICE_ID=""
STRIPE_REALTOR_PRICE_ID=""
STRIPE_BILLING_PORTAL_RETURN_URL=""
