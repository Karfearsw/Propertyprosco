# Stripe billing. Required to enable paid Pro and Realtor subscriptions.
# In production, use live Stripe keys and live price IDs.
# Mapping for this app:
# - STRIPE_REALTOR_PRICE_ID => Realtor base signup plan
# - STRIPE_PRO_PRICE_ID => Pro base signup plan
# - STRIPE_PRO_UPSELL_STARTER_PRICE_ID => Pro Starter upsell tier
# - STRIPE_PRO_UPSELL_PRO_PRICE_ID => Pro upsell tier
# - STRIPE_PRO_UPSELL_ELITE_PRICE_ID => Pro Elite upsell tier
# Expected formats:
# - STRIPE_SECRET_KEY => sk_live_...
# - NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY => pk_live_...
# - STRIPE_WEBHOOK_SECRET => whsec_...
# - all Stripe price IDs => price_...
STRIPE_SECRET_KEY=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_PRO_PRICE_ID=""
STRIPE_REALTOR_PRICE_ID=""
STRIPE_PRO_UPSELL_STARTER_PRICE_ID=""
STRIPE_PRO_UPSELL_PRO_PRICE_ID=""
STRIPE_PRO_UPSELL_ELITE_PRICE_ID=""
STRIPE_BILLING_PORTAL_RETURN_URL=""
