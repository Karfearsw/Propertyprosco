generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  HOMEOWNER
  PRO
  REALTOR
  ADMIN
}

enum ProjectStatus {
  OPEN
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum QuoteStatus {
  PENDING
  VIEWED
  ACCEPTED
  DECLINED
}

enum SubscriptionStatus {
  CHECKOUT_PENDING
  ACTIVE
  PAST_DUE
  CANCELED
  INCOMPLETE
}

enum ProjectPaymentStatus {
  REQUIRES_ACTION
  SUCCEEDED
  FAILED
  CANCELED
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  name          String?
  firstName     String?
  lastName      String?
  image         String?
  password      String?
  phone         String?
  zipCode       String?
  emailNotifications Boolean @default(true)
  smsNotifications   Boolean @default(false)
  marketingEmails    Boolean @default(false)
  role          UserRole  @default(HOMEOWNER)
  homeownerStripeCustomerId             String?
  homeownerStripeDefaultPaymentMethodId String?
  homeownerStripePaymentMethodAddedAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts         Account[]
  sessions         Session[]
  proProfile       ProProfile?
  realtorProfile   RealtorProfile?
  projectsPosted   Project[]      @relation("ProjectOwner")
  quotes           Quote[]        @relation("ProQuotes")
  sentMessages     Message[]      @relation("MessageSender")
  receivedMessages Message[]      @relation("MessageReceiver")
  notifications    Notification[]
  savedPros        SavedPro[]
  reviews          Review[]       @relation("ReviewAuthor")
  reviewsReceived  Review[]       @relation("ReviewSubject")
  homeownerPayments ProjectPayment[] @relation("ProjectPaymentHomeowner")
  proPayments       ProjectPayment[] @relation("ProjectPaymentPro")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model ProProfile {
  id                           String             @id @default(cuid())
  userId                       String             @unique
  businessName                 String?
  bio                          String?
  services                     String[]
  serviceArea                  String[]
  yearsExp                     Int?
  licenseNumber                String?
  insured                      Boolean            @default(false)
  licensed                     Boolean            @default(false)
  backgroundCheck              Boolean            @default(false)
  rating                       Float              @default(0)
  reviewCount                  Int                @default(0)
  profileComplete              Int                @default(0)
  subscriptionStatus           SubscriptionStatus @default(CHECKOUT_PENDING)
  billingActivatedAt           DateTime?
  subscriptionCurrentPeriodEnd DateTime?
  subscriptionCanceledAt       DateTime?
  stripeCustomerId             String?
  stripeSubscriptionId         String?            @unique
  stripePriceId                String?
  stripeProductId              String?
  createdAt                    DateTime           @default(now())
  updatedAt                    DateTime           @updatedAt

  user    User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  leads   ProLead[]
  schedule ScheduleEntry[]
}

model RealtorProfile {
  id                           String             @id @default(cuid())
  userId                       String             @unique
  agencyName                   String?
  licenseNumber                String?
  subscriptionStatus           SubscriptionStatus @default(CHECKOUT_PENDING)
  billingActivatedAt           DateTime?
  subscriptionCurrentPeriodEnd DateTime?
  subscriptionCanceledAt       DateTime?
  stripeCustomerId             String?
  stripeSubscriptionId         String?            @unique
  stripePriceId                String?
  stripeProductId              String?
  createdAt                    DateTime           @default(now())
  updatedAt                    DateTime           @updatedAt

  user    User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  clients RealtorClient[]
}

model Project {
  id          String        @id @default(cuid())
  ownerId     String
  realtorClientId String?
  title       String
  description String?
  category    String
  budget      String?
  zipCode     String?
  address     String?
  status      ProjectStatus @default(OPEN)
  urgent      Boolean       @default(false)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  owner         User           @relation("ProjectOwner", fields: [ownerId], references: [id])
  realtorClient RealtorClient? @relation(fields: [realtorClientId], references: [id], onDelete: SetNull)
  quotes        Quote[]
  leads         ProLead[]
  payment      ProjectPayment?

  @@index([realtorClientId])
}

model ProjectPayment {
  id                   String               @id @default(cuid())
  projectId             String               @unique
  homeownerId           String
  proId                 String?
  jobAmountCents        Int
  platformFeeCents      Int
  totalAmountCents      Int
  currency              String               @default("usd")
  status                ProjectPaymentStatus @default(REQUIRES_ACTION)
  stripePaymentIntentId String               @unique
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt

  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  homeowner User    @relation("ProjectPaymentHomeowner", fields: [homeownerId], references: [id], onDelete: Cascade)
  pro       User?   @relation("ProjectPaymentPro", fields: [proId], references: [id], onDelete: SetNull)
}

model Quote {
  id        String      @id @default(cuid())
  projectId String
  proId     String
  amount    Float
  message   String?
  status    QuoteStatus @default(PENDING)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  project Project @relation(fields: [projectId], references: [id])
  pro     User    @relation("ProQuotes", fields: [proId], references: [id])
}

model ProLead {
  id        String   @id @default(cuid())
  proId     String
  projectId String
  status    String   @default("new")
  saved     Boolean  @default(false)
  viewedAt  DateTime?
  createdAt DateTime @default(now())

  pro     ProProfile @relation(fields: [proId], references: [id])
  project Project    @relation(fields: [projectId], references: [id])

  @@unique([proId, projectId])
}

model Message {
  id         String   @id @default(cuid())
  senderId   String
  receiverId String
  content    String   @db.Text
  read       Boolean  @default(false)
  createdAt  DateTime @default(now())

  sender   User @relation("MessageSender",   fields: [senderId],   references: [id])
  receiver User @relation("MessageReceiver", fields: [receiverId], references: [id])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String
  title     String
  body      String
  read      Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model RealtorClient {
  id         String   @id @default(cuid())
  realtorId  String
  name       String
  address    String?
  email      String?
  phone      String?
  status     String   @default("active")
  notes      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  realtor RealtorProfile @relation(fields: [realtorId], references: [id])
  projects Project[]
}

model ScheduleEntry {
  id        String   @id @default(cuid())
  proId     String
  title     String
  client    String?
  address   String?
  date      DateTime
  duration  Int?
  notes     String?
  status    String   @default("confirmed")
  createdAt DateTime @default(now())

  pro ProProfile @relation(fields: [proId], references: [id])
}

model Review {
  id         String   @id @default(cuid())
  authorId   String
  subjectId  String
  projectId  String?
  rating     Int
  comment    String?
  createdAt  DateTime @default(now())

  author  User @relation("ReviewAuthor",  fields: [authorId],  references: [id])
  subject User @relation("ReviewSubject", fields: [subjectId], references: [id])
}

model SavedPro {
  id         String   @id @default(cuid())
  homeownerId String
  proId       String
  createdAt  DateTime @default(now())

  homeowner User @relation(fields: [homeownerId], references: [id])

  @@unique([homeownerId, proId])
}
