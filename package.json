{
  "name": "property-pros",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --port 5000 --hostname 0.0.0.0",
    "build": "npm run validate:env:production && prisma generate && next build",
    "start": "next start --port 5000 --hostname 0.0.0.0",
    "typecheck": "tsc --noEmit",
    "test": "tsx --test tests/**/*.test.ts",
    "prisma:validate": "prisma validate",
    "validate:env": "tsx scripts/validate-env.ts",
    "validate:env:production": "tsx scripts/validate-env.ts --target=production",
    "verify": "npm run prisma:validate && npm run typecheck && npm run test",
    "db:push:local": "prisma db push",
    "db:migrate:dev": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:migrate:status": "prisma migrate status",
    "db:generate": "prisma generate",
    "db:studio": "prisma studio",
    "db:seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.7.2",
    "@auth0/nextjs-auth0": "^4.22.0",
    "@prisma/client": "^6.2.1",
    "@stripe/react-stripe-js": "^6.6.0",
    "@stripe/stripe-js": "^9.8.0",
    "@types/nodemailer": "^6.4.17",
    "bcryptjs": "^2.4.3",
    "clsx": "^2.1.1",
    "lucide-react": "^0.474.0",
    "next": "15.3.9",
    "next-auth": "5.0.0-beta.31",
    "nodemailer": "^7.0.13",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "stripe": "^22.2.2",
    "tailwind-merge": "^2.6.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "autoprefixer": "^10.4.20",
    "dotenv": "^16.6.1",
    "postcss": "^8",
    "prisma": "^6.2.1",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.2",
    "typescript": "^5"
  }
}
